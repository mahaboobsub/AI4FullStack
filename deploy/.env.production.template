# ================================================================
# BloodBridge AI — Production Environment Variables Template
# ================================================================
# Copy this file to .env.production and fill in your actual values.
# NEVER commit .env.production to Git!
# ================================================================

# ── Application ──────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://YOUR_DOMAIN
WEB_PORTAL_URL=https://YOUR_DOMAIN
LOG_LEVEL=INFO
DEMO_MOCK_MODE=false
THREE_PHONE_DEMO_MODE=false

# ── CORS — set to your frontend domain ──────────────────────────
# For same-domain setup (frontend + backend on same EC2), use your domain.
# For separate domains, comma-separate them.
ALLOWED_ORIGINS=https://YOUR_DOMAIN

# ── Supabase (copy from your Supabase dashboard) ────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Neo4j Aura (copy from your Neo4j Aura dashboard) ────────────
NEO4J_URI=neo4j+s://YOUR_NEO4J.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

# ── AWS Bedrock (for Claude AI — LLM calls) ─────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# ── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_WEBHOOK_URL=https://YOUR_DOMAIN/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_32_CHAR_SECRET

# ── Bolna.ai (Voice calls — optional) ───────────────────────────
BOLNA_API_KEY=
BOLNA_AGENT_ID=
BOLNA_WEBHOOK_SECRET=

# ── Twilio SMS (optional) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Security ────────────────────────────────────────────────────
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING

# ── ntfy.sh alerts (optional) ──────────────────────────────────
NTFY_TOPIC=bloodbridge-alerts
