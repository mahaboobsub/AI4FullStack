# Supabase  
SUPABASE_URL=  
SUPABASE_KEY=  
SUPABASE_SERVICE_KEY=

# Neo4j Aura  
NEO4J_URI=  
NEO4J_USERNAME=  
NEO4J_PASSWORD=

# AWS Bedrock + Textract (blood card OCR in Telegram)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional model overrides (defaults: Haiku fast/reasoning, Sonnet quality+vision)
# BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6
# Telegram  
TELEGRAM_BOT_TOKEN=  
TELEGRAM_WEBHOOK_URL=  
TELEGRAM_WEBHOOK_SECRET=         # random 32-char string for webhook verification

# Vapi.ai (Voice calls — replaces Twilio Voice)  
VAPI_API_KEY=                    # from Vapi dashboard  
VAPI_PHONE_NUMBER_ID=            # from Vapi dashboard phone number settings  
VAPI_WEBHOOK_SECRET=             # random 32-char string for Vapi webhook verification

# Twilio (SMS only — DLT-registered)  
TWILIO_ACCOUNT_SID=  
TWILIO_AUTH_TOKEN=  
TWILIO_DLT_SENDER_ID=            # India DLT-registered sender ID for SMS  
TWILIO_DLT_TEMPLATE_ID_HI=       # Hindi SMS template ID registered with DLT  
TWILIO_DLT_TEMPLATE_ID_EN=       # English SMS template ID

# ntfy.sh  
NTFY_TOPIC=bloodbridge-alerts

# App settings  
APP_ENV=development  
APP_HOST=0.0.0.0  
APP_PORT=8000  
APP_BASE_URL=http://localhost:8000  
WEB_PORTAL_URL=http://localhost:5173  
LOG_LEVEL=INFO  
# Local hackathon demos: true (simulated voice + Neo4j fallback). Live APIs: false. See DEMO_MODE.md
DEMO_MOCK_MODE=true
# Restrict to 3 real phones — run: python -m data.seed_three_phones
THREE_PHONE_DEMO_MODE=true
